#!/bin/bash
set -e
case "$1" in
    configure)
        SHARE="/usr/share/voxfree"
        BIN="/usr/local/bin"

        # Always re-copy runtime scripts and the unified CLI wrapper from /usr/share/voxfree/
        # so that upgrades via dpkg pick up new versions without re-running interactive setup.
        for F in \
            ReadLoud/voxfree-readloud.sh:voxfree-readloud \
            ReadLoud/voxfree-readloud-stop.sh:voxfree-readloud-stop \
            ReadLoud/voxfree-stop-all.sh:voxfree-stop-all \
            ReadLoud/voxfree-readloud-last.sh:voxfree-readloud-last \
            ReadLoud/voxfree-indicator:voxfree-indicator \
            SpeakToType/voxfree-dictate.sh:voxfree-dictate \
            SpeakToType/voxfree-dictate-stop.sh:voxfree-dictate-stop; do
            SRC="${F%%:*}"
            DEST="${F##*:}"
            [ -f "$SHARE/$SRC" ] && install -m 755 "$SHARE/$SRC" "$BIN/$DEST"
        done
        # Install state library
        install -m 644 "$SHARE/lib/state.sh" "$BIN/lib/state.sh" 2>/dev/null || true

        # Re-copy the thin CLI wrappers that live in /usr/share/voxfree/ but
        # are also exposed in /usr/local/bin/ via the deb. This keeps them in
        # sync when upgrading via dpkg without re-running install.sh.
        for F in voxfree voxfree-voice voxfree-uninstall; do
            [ -f "$SHARE/$F" ] && install -m 755 "$SHARE/$F" "$BIN/$F"
        done

        # Also update user-level scripts (~/.local/bin/) if they were previously
        # installed via 'install.sh --user' — prevents shortcut path mismatch on
        # .deb upgrades (shortcuts point to ~/.local/bin/ but only /usr/local/bin/
        # gets updated otherwise).
        for RUNID in /run/user/*; do
            USERID="${RUNID#/run/user/}"
            UHOME=$(getent passwd "$USERID" 2>/dev/null | cut -d: -f6)
            [ -z "$UHOME" ] && continue
            mkdir -p "$UHOME/.local/bin/lib" 2>/dev/null || true
            for F in \
                ReadLoud/voxfree-readloud.sh:voxfree-readloud \
                ReadLoud/voxfree-readloud-stop.sh:voxfree-readloud-stop \
                ReadLoud/voxfree-stop-all.sh:voxfree-stop-all \
                ReadLoud/voxfree-readloud-last.sh:voxfree-readloud-last \
                ReadLoud/voxfree-indicator:voxfree-indicator \
                SpeakToType/voxfree-dictate.sh:voxfree-dictate \
                SpeakToType/voxfree-dictate-stop.sh:voxfree-dictate-stop; do
                SRC="${F%%:*}"
                DEST="${F##*:}"
                [ -f "$SHARE/$SRC" ] && [ -d "$UHOME/.local/bin" ] && \
                    install -m 755 "$SHARE/$SRC" "$UHOME/.local/bin/$DEST" 2>/dev/null || true
            done
            install -m 644 "$SHARE/lib/state.sh" "$UHOME/.local/bin/lib/state.sh" 2>/dev/null || true
        done
        # Install GNOME Shell extension
        EXT_DIR="/usr/share/gnome-shell/extensions/voxfree@voxfree.app"
        mkdir -p "$EXT_DIR"
        if [ -d "$SHARE/ReadLoud/gnome-shell-extension" ]; then
            cp "$SHARE/ReadLoud/gnome-shell-extension/"*.js "$SHARE/ReadLoud/gnome-shell-extension/"*.json "$EXT_DIR/" 2>/dev/null || true
        fi

        # Enable extension if gnome-extensions is available
        if command -v gnome-extensions >/dev/null 2>&1; then
            gnome-extensions enable voxfree@voxfree.app 2>/dev/null || true
        fi

        # Fresh install: run interactive configuration if a terminal is available.
        # Upgrade (2 is the old version passed by dpkg): scripts are updated above,
        # no interactive setup needed.
        if [ -z "$2" ]; then
            # Fresh install
            if [ -t 0 ]; then
                echo ""
                echo "VoxFree installed. Running configuration..."
                bash "$SHARE/install.sh" --postinst-mode
            else
                echo ""
                echo "VoxFree installed successfully."
                echo "Run the following to configure keyboard shortcuts and dependencies:"
                echo "  sudo voxfree --install"
                echo ""
                echo "To start the system tray indicator now:"
                echo "  voxfree-indicator"
                echo ""
                echo "Or run the health check:"
                echo "  voxfree --doctor"
            fi
        else
            # Upgrade from $2 → installed version
            echo ""
            echo "VoxFree upgraded to $(cat $SHARE/VERSION 2>/dev/null || echo unknown)."
            echo "Runtime scripts updated. No reconfiguration needed."
            echo ""
            echo "New in 0.4.0: system tray indicator"
            echo "  voxfree-indicator      — start the indicator"
            echo "  voxfree-readloud-last  — replay last spoken text"
            echo ""
            echo "Run 'voxfree --doctor' to verify."
            echo ""
        fi
        ;;
esac
